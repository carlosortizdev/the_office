{
  "manifest_version": 3,
  "name": "Prank Planner",
  "version": "1.0.0",
  "description": "Jim Halpert's personal prank idea notebook. Looks like a productivity tool. It is not.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prank Planner"
